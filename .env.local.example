# Copy to .env.local and fill in your key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (claude-opus-4-8).
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: password-protect the whole site (HTTP Basic Auth).
# Leave unset for an open site (e.g. local dev).
#
# A single (admin) account:
# SITE_USER=admin
# SITE_PASSWORD=change-me
#
# Additional accounts (so you don't share the admin login), as comma-separated
# "user:pass" pairs. Passwords may contain ':' but not ','.
# SITE_USERS=guest:lookaround,leon:s3cret
