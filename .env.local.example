# Copy to .env.local and fill in your key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the default model (claude-opus-4-8).
# ANTHROPIC_MODEL=claude-sonnet-5

# Optional: password-protect the whole site (HTTP Basic Auth).
# Set BOTH to enable the gate; leave unset for an open site (e.g. local dev).
# SITE_USER=admin
# SITE_PASSWORD=change-me
